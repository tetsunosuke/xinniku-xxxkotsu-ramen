---
// src/pages/index.astro
// Astro serves src/pages as routes. Having an empty src/pages was causing a 404 because
// Astro's routing didn't map the root '/' to public/index.html in dev mode.
// By creating a simple index.astro that imports and renders our HTML content or reads it,
// we ensure Astro dev server serves it correctly!
import fs from 'fs';
import path from 'path';

const htmlPath = path.resolve('public/index.html');
const htmlContent = fs.readFileSync(htmlPath, 'utf-8');
// Extract the body content or just serve it as is.
// The cleanest way is to render the raw HTML directly.
---
<Fragment set:html={htmlContent} />
